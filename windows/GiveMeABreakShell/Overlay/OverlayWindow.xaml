<Window x:Class="GiveMeABreakShell.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Background="#0A0D17" Focusable="True"
        KeyDown="OnKeyDown">
    <!-- 全屏强制遮罩（每屏一个 Window，由 FullscreenOverlayController 设 Left/Top/Width/Height）。
         UI 镜像 macOS OverlayContentView：倒计时态 vs 确认态（IsConfirming 切换）。 -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.97">
                <GradientStop Color="#0A0D17" Offset="0"/>
                <GradientStop Color="#170F24" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 倒计时态 -->
        <StackPanel x:Name="CountdownPanel" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="🍃" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Give me a break" Foreground="#D9FFFFFF" FontSize="34"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>
            <TextBlock x:Name="CountdownText" Foreground="White" FontSize="130" FontWeight="Bold"
                       HorizontalAlignment="Center" FontFamily="Consolas"/>
            <TextBlock Text="双击 Esc 直接结束休息" Foreground="#73FFFFFF" FontSize="16"
                       HorizontalAlignment="Center" Margin="0,28,0,0"/>
        </StackPanel>

        <!-- 确认态（提前结束） -->
        <StackPanel x:Name="ConfirmPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="提前结束休息？" Foreground="White" FontSize="30" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="休息尚未到时，提前结束将重置计时器。" Foreground="#B3FFFFFF" FontSize="17"
                       HorizontalAlignment="Center" Margin="0,0,0,22" TextWrapping="Wrap"
                       MaxWidth="400" TextAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="继续休息" FontSize="18" Margin="0,0,18,0" Padding="20,8" Click="OnContinueClick"/>
                <Button Content="直接退出" FontSize="18" Padding="20,8" Click="OnExitClick"/>
            </StackPanel>
            <TextBlock Text="按 Esc 取消，返回休息" Foreground="#73FFFFFF" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,22,0,0"/>
        </StackPanel>
    </Grid>
</Window>
